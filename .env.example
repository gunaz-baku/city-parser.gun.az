APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Server (canlı): APP_URL=https://city-parser.gun.az

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=city_parser.gun.az
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Wolt: default HTTP. ChromeDriver ilə JS render üçün: WOLT_USE_WEBDRIVER=true və chromedriver işləsin.
# WOLT_USE_WEBDRIVER=false
# CHROME_DRIVER_URL=http://127.0.0.1:9515
# Sürətli test: WOLT_PARSER_MAX_PRODUCTS=2 php artisan parser:run wolt && php artisan queue:work redis --queue=parser-orchestration,parser-bina,parser-wolt,default --stop-when-empty
# Bina: BINA_PARSER_MAX_SOURCES=3 (yalnız ilk N mənbə)
# Bina: listing üçün GraphQL (SSR-də kart yoxdur). Söndürmək: BINA_USE_GRAPHQL=false
# BINA_GRAPHQL_URL=https://bina.az/graphql

# ---------------------------------------------------------------------------
# HTTP Basic — /api/v1/control/parser/run/{wolt|bina} (GunAz Filament və s.)
# users.email + parol; sonra: php artisan parser:ensure-basic-user (city-parser hostunda).
# Paylaşılmış .env: GunAz eyni faylı oxuyursa, bu iki açar hər iki tətbiq üçün kifayətdir.
# PARSER_BASIC_USERNAME=parser-control@example.com
# PARSER_BASIC_PASSWORD=change-me-strong-password
# ---------------------------------------------------------------------------

# gun.az: snapshot-ları bu parserdən çəkir (Bearer token eyni müştəri + server üçün).
# GUN_AZ_API_TOKEN=  # məcburi: GET/POST /api/v1/parser/* üçün
# Brauzerdə JSON görmək: GET .../api/v1/parser/price-snapshots?token=TOKEN&limit=10
# Tək mənbə nəticələri: GET .../source-price-results?token=TOKEN&parser_run_id=1&limit=50
# Şəhər səhifəsi (avg cədvəl): GET .../city-price-averages?token=TOKEN  (city_code verilməsə default: baku)
# GUN_AZ_PUSH_ENABLED=false  # default: pull; true olanda parser gun.az-a POST edir (köhnə rejim)
# GUN_AZ_API_URL=https://gun.az
# GUN_AZ_ENDPOINT_PRICE_SNAPSHOTS=/api/v1/parser/price-snapshots
# GUN_AZ_ENDPOINT_BASKET_SNAPSHOTS=/api/v1/parser/basket-snapshots
